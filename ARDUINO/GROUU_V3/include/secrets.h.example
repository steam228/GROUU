// ============================================================================
//  secrets.h  —  LoRaWAN OTAA credentials (The Things Network).
//
//  COPY this file to  include/secrets.h  and fill in your keys.
//  secrets.h is GITIGNORED — never commit real keys.
//
//  From TTN Console → your device → "Activation information"
//  (set the byte-order toggle to MSB):
//    JoinEUI (AppEUI)  — 64-bit, MSB
//    DevEUI            — 64-bit, MSB
//    AppKey            — 16 bytes, MSB
// ============================================================================
#pragma once

// 64-bit EUIs as 0x-prefixed literals (MSB first)
#define SECRET_JOIN_EUI   0x0000000000000000
#define SECRET_DEV_EUI    0x0000000000000000

// 16-byte AppKey, MSB first
#define SECRET_APP_KEY { 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, \
                         0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00 }
