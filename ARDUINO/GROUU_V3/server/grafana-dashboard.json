{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "Your InfluxDB 2.x (Flux) data source",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "",
  "title": "WellBouy — Water Quality",
  "tags": ["wellbouy", "lorawan"],
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "🌊 Water Quality — Live",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 1,
      "type": "gauge",
      "title": "Temperature",
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius", "decimals": 1, "min": 0, "max": 40,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "blue", "value": null },
            { "color": "green", "value": 5 },
            { "color": "orange", "value": 30 }
          ] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false, "showThresholdMarkers": true,
        "orientation": "auto", "sizing": "auto"
      },
      "targets": [ { "refId": "A", "query": "from(bucket: \"wellbouy\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"wellbouy\" and r._field == \"temperature\")\n  |> last()" } ]
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "TDS",
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "conppm", "decimals": 0, "min": 0, "max": 2000,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 500 },
            { "color": "red", "value": 1000 }
          ] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false, "showThresholdMarkers": true,
        "orientation": "auto", "sizing": "auto"
      },
      "targets": [ { "refId": "A", "query": "from(bucket: \"wellbouy\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"wellbouy\" and r._field == \"tds\")\n  |> last()" } ]
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Turbidity",
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "suffix:NTU", "decimals": 0, "min": 0, "max": 1000,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 50 },
            { "color": "red", "value": 250 }
          ] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false, "showThresholdMarkers": true,
        "orientation": "auto", "sizing": "auto"
      },
      "targets": [ { "refId": "A", "query": "from(bucket: \"wellbouy\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"wellbouy\" and r._field == \"turbidity\")\n  |> last()" } ]
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "pH",
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "none", "decimals": 2, "min": 0, "max": 14,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "orange", "value": 6 },
            { "color": "green", "value": 6.5 },
            { "color": "orange", "value": 8.5 },
            { "color": "red", "value": 9 }
          ] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false, "showThresholdMarkers": true,
        "orientation": "auto", "sizing": "auto"
      },
      "targets": [ { "refId": "A", "query": "from(bucket: \"wellbouy\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"wellbouy\" and r._field == \"ph\")\n  |> last()" } ]
    },
    {
      "id": 101,
      "type": "row",
      "title": "📈 Water Quality — Over Time",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Temperature",
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "always", "pointSize": 5, "spanNulls": true, "axisPlacement": "auto" }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "single", "sort": "none" }, "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] } },
      "targets": [ { "refId": "A", "query": "from(bucket: \"wellbouy\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"wellbouy\" and r._field == \"temperature\")\n  |> keep(columns: [\"_time\", \"_value\"])" } ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "TDS",
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "conppm",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "always", "pointSize": 5, "spanNulls": true, "axisPlacement": "auto" }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "single", "sort": "none" }, "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] } },
      "targets": [ { "refId": "A", "query": "from(bucket: \"wellbouy\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"wellbouy\" and r._field == \"tds\")\n  |> keep(columns: [\"_time\", \"_value\"])" } ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Turbidity",
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "fieldConfig": {
        "defaults": {
          "unit": "suffix:NTU",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "always", "pointSize": 5, "spanNulls": true, "axisPlacement": "auto" }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "single", "sort": "none" }, "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] } },
      "targets": [ { "refId": "A", "query": "from(bucket: \"wellbouy\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"wellbouy\" and r._field == \"turbidity\")\n  |> keep(columns: [\"_time\", \"_value\"])" } ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "pH",
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "fieldConfig": {
        "defaults": {
          "unit": "none", "decimals": 2,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "always", "pointSize": 5, "spanNulls": true, "axisPlacement": "auto" }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "single", "sort": "none" }, "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] } },
      "targets": [ { "refId": "A", "query": "from(bucket: \"wellbouy\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"wellbouy\" and r._field == \"ph\")\n  |> keep(columns: [\"_time\", \"_value\"])" } ]
    },
    {
      "id": 102,
      "type": "row",
      "title": "📡 Device & Connectivity",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "RSSI (now)",
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 26 },
      "fieldConfig": {
        "defaults": {
          "unit": "dBm", "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "orange", "value": -110 },
            { "color": "green", "value": -100 }
          ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [ { "refId": "A", "query": "from(bucket: \"wellbouy\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"wellbouy\" and r._field == \"rssi\")\n  |> last()" } ]
    },
    {
      "id": 10,
      "type": "stat",
      "title": "SNR (now)",
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 26 },
      "fieldConfig": {
        "defaults": {
          "unit": "suffix:dB", "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "orange", "value": 0 },
            { "color": "green", "value": 5 }
          ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [ { "refId": "A", "query": "from(bucket: \"wellbouy\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"wellbouy\" and r._field == \"snr\")\n  |> last()" } ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "LoRa link (RSSI / SNR)",
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 26 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5, "showPoints": "always", "pointSize": 4, "spanNulls": true, "axisPlacement": "auto" }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi", "sort": "none" }, "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] } },
      "targets": [ { "refId": "A", "query": "from(bucket: \"wellbouy\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"wellbouy\" and (r._field == \"rssi\" or r._field == \"snr\"))\n  |> keep(columns: [\"_time\", \"_value\", \"_field\"])" } ]
    }
  ]
}
