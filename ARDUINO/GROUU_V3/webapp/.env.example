# WellBouy dashboard — copy to .env and fill in. Leave INFLUX_TOKEN blank to run
# in DEMO mode (synthetic data, no database needed).
PORT=3000

# InfluxDB 2.x (same instance Node-RED writes to)
INFLUX_URL=http://influxdb:8086      # container name if same Docker network, else host:8086
INFLUX_TOKEN=                        # a read token for the wellbouy bucket
INFLUX_ORG=your-org
INFLUX_BUCKET=wellbouy
INFLUX_MEASUREMENT=wellbouy

# Force demo data even if a token is set (handy for a public preview):
# DEMO=1
